# Public base path for hosted deployments that live under a subpath, e.g. /coogpath
NEXT_PUBLIC_BASE_PATH=

# Use one of the API options below:
# 1) For a Next.js server that proxies API requests, set API_URL only.
API_URL=

# 2) For static hosting or direct browser-to-backend calls, set NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_URL=
